# ============================================================================
# 双信号门控连续自适应MST策略 - Git忽略文件
# ============================================================================

# ----------------------------------------------------------------------------
# 操作系统生成文件
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ----------------------------------------------------------------------------
# MATLAB 临时/备份文件
# ----------------------------------------------------------------------------
*.asv          # MATLAB 自动保存文件
*.m~           # MATLAB 备份文件
*.autosave     # MATLAB 自动保存
*.matlab       # MATLAB 临时文件
slprj/         # Simulink 项目文件

# ----------------------------------------------------------------------------
# 生成的结果文件 (实验输出，不应版本控制)
# ----------------------------------------------------------------------------
# 数据文件
*.mat

# 图片文件 (生成的图表)
*.png
*.fig
*.jpg
*.jpeg
*.pdf
*.eps
*.svg

# 报告/日志文件
*.md
*.txt
*.log
*.csv

# 时间戳结果目录 (按日期命名的结果文件夹)
*_20*/

# ----------------------------------------------------------------------------
# Claude AI 状态文件
# ----------------------------------------------------------------------------
.claude/
.claude-snapshots/

# ----------------------------------------------------------------------------
# 已删除的文件夹
# ----------------------------------------------------------------------------
.alma-snapshots/

# ----------------------------------------------------------------------------
# 编辑器/IDE 配置文件
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-*

# ----------------------------------------------------------------------------
# 临时文件
# ----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.old

# ----------------------------------------------------------------------------
# 打包/压缩文件
# ----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ----------------------------------------------------------------------------
# 大型二进制文件 (如需要版本控制，请手动添加)
# ----------------------------------------------------------------------------
# 示例：视频、大型数据集等
*.mp4
*.avi
*.mov
*.h5
*.hdf5
